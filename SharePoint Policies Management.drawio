        <mxCell id="dw8o1Iwls4ASfkwBR7E6-45" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Convert file to pdf&lt;/h1&gt;&lt;p&gt;currently no way to preserve the original file&#39;s Approval status if convert file to pdf because SharePoint will treat as a new file.&lt;/p&gt;" vertex="1">
          <mxGeometry height="110" width="220" x="510" y="420" as="geometry" />
        </mxCell>
        <mxCell id="dw8o1Iwls4ASfkwBR7E6-46" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Add documents to an envelope&lt;/h1&gt;&lt;p&gt;DocuSign will convert them to PDF format for sending and storage. So we don&#39;t need to perform the same action.&lt;/p&gt;&lt;p&gt;&amp;gt;&amp;gt;DocuSign supports a wide variety of file formats, covering the popular document, presentation, image, drawing, and spreadsheet applications. When you add your files, Docusign converts them to PDF format for sending and storage.&lt;/p&gt;&lt;p&gt;https://support.docusign.com/s/document-item?language=en_US&amp;amp;bundleId=ulp1643236876813&amp;amp;topicId=crk1578456412036.html&amp;amp;_LANG=zhtw&amp;amp;langSet=1&lt;/p&gt;" vertex="1">
