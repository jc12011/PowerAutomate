        <mxCell id="dw8o1Iwls4ASfkwBR7E6-44" parent="1" style="rhombus;whiteSpace=wrap;html=1;" value="&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: center; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(236, 236, 236); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;If Users clicked Approve / Reject / Cancel request&lt;/span&gt;&lt;br&gt;button" vertex="1">
          <mxGeometry height="100" width="150" x="350" y="130" as="geometry" />
        </mxCell>
        <mxCell id="dw8o1Iwls4ASfkwBR7E6-46" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;1. Add documents to an envelope&lt;/h1&gt;&lt;p&gt;DocuSign will convert them to PDF format for sending and storage. So we don&#39;t need to perform the same action.&lt;/p&gt;&lt;p&gt;&amp;gt;&amp;gt;DocuSign supports a wide variety of file formats, covering the popular document, presentation, image, drawing, and spreadsheet applications. When you add your files, Docusign converts them to PDF format for sending and storage.&lt;/p&gt;&lt;p&gt;https://support.docusign.com/s/document-item?language=en_US&amp;amp;bundleId=ulp1643236876813&amp;amp;topicId=crk1578456412036.html&amp;amp;_LANG=zhtw&amp;amp;langSet=1&lt;/p&gt;" vertex="1">
          <mxGeometry height="160" width="660" x="30" y="820" as="geometry" />
        </mxCell>
